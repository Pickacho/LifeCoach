# Database path in docker container
DB_PATH=/app/data/coach.db

# App Port
PORT=3000

# LLM Configuration (OpenAI SDK Compatible)
# Example for OpenRouter: https://openrouter.ai/api/v1
# Example for LM Studio from INSIDE Docker: http://host.docker.internal:1234/v1
# (Note: Use host.docker.internal instead of localhost when running inside Docker container)
LLM_BASE_URL=http://host.docker.internal:1234/v1
LLM_API_KEY=your-api-key-here
LLM_MODEL=local-model
